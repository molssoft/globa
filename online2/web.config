<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <staticContent>
            <clientCache cacheControlMode="NoControl" cacheControlMaxAge="00:00:00" />
        </staticContent>
        <caching maxCacheSize="0" />
        <urlCompression doStaticCompression="false" doDynamicCompression="false" />
    </system.webServer>
</configuration>
